  "implicit_baseline_per_device": {
    "comment": "Per spec section 3.2, B2 (Device Details) and B6 (Recent Alerts) always render on EVERY device-slider entity (B2 = identity card; B6 = correlated alerts) regardless of which log-types the device emits. Per-log-type 'baseline' arrays above list ONLY the data-driven sub-sections that the specific log-type can feed; the always-on B2 and B6 are added by the slider at render time.",
    "always_on_for_device": ["B2", "B6"],
    "always_on_for_other":  ["OB2", "OB4"]
  },
  "implicit_enriched_per_device": {
    "comment": "Per spec section 3.3, E1 (Agent Status & Health) and E2 (GPO Applied) are derived from agent-registry + GPO-discovery joins, not from the per-log-type event stream. They render after Investigate Entity for any Windows-family device with an agent / GPO scope, independent of whether the listed enriched array includes them.",
    "agent_health_for_device":     "E1",
    "gpo_for_windows_family":      "E2"
  }
