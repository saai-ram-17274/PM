        { "field": "dstPort", "source": "DST_PORT", "type": "integer" },
        { "field": "protocol", "source": "PROTOCOL_TR", "type": "string", "note": "L4 only: tcp/udp/icmp" },
        { "field": "threatId", "source": "THREAT_ID", "type": "string" },
        { "field": "protectionName", "source": "PROTECTION_NAME", "type": "string" },
        { "field": "attack", "source": "ATTACK", "type": "string" },
        { "field": "subtype", "source": "SUBTYPE", "type": "string" },
        { "field": "severityLevel", "source": "COALESCE(SEVERITYLEVEL, SEVERITY)", "type": "string" },
        { "field": "actionTag", "source": "ACTION_TAG", "type": "string" },
        { "field": "action", "source": "ACTION", "type": "string" },
        { "field": "rawMessage", "source": "MESSAGE", "type": "string", "note": "truncated to 500 chars; fallback for vendors whose parser didn't extract a signature column" }
      ],
      "_vendorPopulationReference": {
        "_note": "Informational only. Documents which columns each parser fills so analyst knows what 'blank' means. NOT consumed by frontend.",
        "paloalto device": ["threatId", "subtype", "severityLevel", "actionTag", "rawMessage"],
        "checkpoint device": ["protectionName", "attack", "severityLevel", "action", "rawMessage"],
        "fortinet device": ["subtype", "actionTag", "rawMessage"],
        "cisco device": ["rawMessage"]
      }
    },
