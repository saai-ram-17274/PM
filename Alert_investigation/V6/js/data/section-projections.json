        { "field": "bytesReceived", "source": "RECEIVED_BYTES", "type": "integer", "status": "partial", "hosttype": ["paloalto","fortinet","sophos","firepower","topsec"], "coverage": { "checkpoint": "unavailable_as_parsed_column" } },
        { "field": "packetsSent", "source": "SENT_PACKETS", "type": "integer", "status": "partial", "hosttype": ["paloalto","fortinet"] },
        { "field": "packetsReceived", "source": "RECEIVED_PACKETS", "type": "integer", "status": "partial", "hosttype": ["paloalto","fortinet"] }
      ]
